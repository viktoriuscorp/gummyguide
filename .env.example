# GummyGuide — variables de entorno
# Copia este archivo a `.env` (no se sube a git) y rellena los valores reales.
#
# REGLA: NUNCA poner credenciales en codigo, config files versionados, o chat.
# Siempre en .env (que esta en .gitignore).

# Firecrawl - para scraping de productos Amazon, SERP analysis, etc.
# Obtén tu key en: https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DataForSEO — keyword research y volumen Google Ads
# Crea cuenta en: https://app.dataforseo.com/
DATAFORSEO_USERNAME=tu-email@ejemplo.com
DATAFORSEO_PASSWORD=xxxxxxxxxxxxxxxx

# Cloudflare - para wrangler deploy (normalmente no necesario, wrangler usa OAuth)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# Amazon Product Advertising API (PA-API) - cuando este aprobada
# AMAZON_PA_API_ACCESS_KEY=
# AMAZON_PA_API_SECRET_KEY=
# AMAZON_PARTNER_TAG=gummyguidepro-20

# GitHub - para automatizacion CI (si se usa, normalmente keychain basta)
# GITHUB_TOKEN=
