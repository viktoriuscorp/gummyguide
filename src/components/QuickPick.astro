---
interface Props {
  name: string;
  brand: string;
  reason: string;
  affiliateUrl: string;
  affiliateProgram?: string;
  image?: string;
  price?: string;
}

const { name, brand, reason, affiliateUrl, affiliateProgram = 'direct', image, price } = Astro.props;
---

<aside class="quick-pick" aria-label="Our top recommendation">
  <div class="quick-pick__header">
    <span class="quick-pick__label">Our Top Pick</span>
  </div>
  <div class="quick-pick__body">
    {image && (
      <img
        src={image}
        alt={`${name} by ${brand}`}
        width="80"
        height="80"
        loading="eager"
        class="quick-pick__image"
      />
    )}
    <div class="quick-pick__info">
      <h3 class="quick-pick__name">{name}</h3>
      <p class="quick-pick__brand">{brand} {price && <span class="quick-pick__price">— {price}</span>}</p>
      <p class="quick-pick__reason">{reason}</p>
    </div>
    <a
      href={affiliateUrl}
      class="btn btn-cta quick-pick__cta"
      rel="nofollow sponsored noopener"
      target="_blank"
      data-affiliate={affiliateProgram}
      data-product={name}
    >
      Check Price
    </a>
  </div>
</aside>
