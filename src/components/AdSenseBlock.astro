---
interface Props {
  slot?: string;
  format?: 'auto' | 'rectangle' | 'horizontal' | 'vertical';
}

const { slot = '', format = 'auto' } = Astro.props;
---

<div class="adsense-block" aria-hidden="true">
  <!-- Google AdSense placeholder — replace with real ad code after approval -->
  <div class="adsense-placeholder" data-ad-slot={slot} data-ad-format={format}>
    <span>Ad Space</span>
  </div>
</div>
