---
// Search CTA block — encourages users to discover more content via the search bar
---

<div class="search-cta">
  <div class="search-cta-inner">
    <h3>Looking for something specific?</h3>
    <p>Search 170+ expert-tested gummy supplement guides — from creatine to collagen, sleep to shilajit.</p>
    <button class="search-cta-btn" id="search-cta-trigger">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      Search GummyGuide
    </button>
  </div>
</div>

<style>
  .search-cta {
    background: #F5F3EE;
    border: 1px solid #E0DDD6;
    border-radius: 20px;
    padding: 32px;
    margin: 40px 0;
    text-align: center;
  }
  .search-cta h3 {
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: #1A1A1A;
    margin-bottom: 8px;
  }
  .search-cta p {
    font-size: 15px;
    color: #6B6B6B;
    margin-bottom: 20px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }
  .search-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: #3D4F2F;
    color: #fff;
    border: none;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    font-family: 'Inter', -apple-system, sans-serif;
  }
  .search-cta-btn:hover { background: #2D3F1F; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var btn = document.getElementById('search-cta-trigger');
    var st = document.getElementById('search-toggle');
    var sb = document.getElementById('search-box');
    var si = document.getElementById('search-input');
    if (btn && st && sb && si) {
      btn.addEventListener('click', function() {
        sb.classList.add('search-open');
        si.focus();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  });
</script>
