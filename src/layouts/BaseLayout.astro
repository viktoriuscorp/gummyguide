---
import '../styles/global.css';
import { getAllCategories } from '../data/categories';
import Icon from '../components/Icon.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const { title, description, canonical, ogImage = '/images/og/default.webp', schema, noindex = false } = Astro.props;
const site = 'https://gummy-guide.com';
const canonicalUrl = canonical || new URL(Astro.url.pathname, site).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, site).href;
const categories = getAllCategories();
const schemas = [
  { '@context': 'https://schema.org', '@type': 'Organization', name: 'GummyGuide', url: site },
  { '@context': 'https://schema.org', '@type': 'WebSite', name: 'GummyGuide', url: site },
  ...(Array.isArray(schema) ? schema : schema ? [schema] : []),
];
