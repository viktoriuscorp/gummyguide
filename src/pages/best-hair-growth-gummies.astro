  image: 'https://gummy-guide.com/images/og/best-hair-growth-gummies.webp',
  mainEntityOfPage: 'https://gummy-guide.com/best-hair-growth-gummies/',
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Best Hair Growth Gummies 2026',
  numberOfItems: 8,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Nutrafol Women\'s Growth Gummies', url: 'https://nutrafol.com/' },
    { '@type': 'ListItem', position: 2, name: 'SugarBear Hair Vitamins', url: 'https://sugarbearhair.com/' },
    { '@type': 'ListItem', position: 3, name: 'Viviscal Hair Growth Gummies', url: 'https://viviscal.com/' },
