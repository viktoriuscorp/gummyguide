const title = "Creatine Before and After: Women — Realistic Results Timeline";
const description = "What women can realistically expect from creatine, week by week. Strength, body composition, cognition, and the visible changes — all backed by research data.";

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Creatine Before and After: Women — Realistic Timeline of Results (2026)',
  description,
  datePublished: '2026-04-26',
  dateModified: '2026-04-26',
  author: { '@type': 'Person', name: 'Sarah Mitchell', jobTitle: 'RD, CNS' },
  publisher: { '@type': 'Organization', name: 'GummyGuide', url: 'https://gummy-guide.com' },
  image: 'https://gummy-guide.com/images/og/creatine-before-and-after-women.webp',
