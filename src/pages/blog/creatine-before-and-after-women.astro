const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How long does it take to see creatine results in women?',
      acceptedAnswer: { '@type': 'Answer', text: 'Most women notice measurable changes within 2-4 weeks of consistent daily creatine supplementation. The earliest visible effect is muscle fullness from intracellular water retention (1-3 pounds scale weight gain). Strength and power improvements typically emerge in weeks 3-6. Body composition changes (visible muscle definition, lean mass gains) generally take 8-12 weeks combined with resistance training. Cognitive benefits like improved memory and reasoning tend to appear within 4-8 weeks of consistent supplementation.' },
    },
    {
      '@type': 'Question',
      name: 'What does creatine before and after look like for women?',
      acceptedAnswer: { '@type': 'Answer', text: 'The most common visible "before and after" change in women is improved muscle definition rather than dramatic size increases. After 8-12 weeks of consistent creatine plus resistance training, women typically see: more visible muscle tone in the arms, shoulders, and quads; a fuller, less flat appearance to muscles; modest 1-3 pound weight gain from intracellular water; and in some cases visible reductions in body fat percentage as lean mass increases support metabolic rate.' },
