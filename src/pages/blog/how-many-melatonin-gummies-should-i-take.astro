            <td>1mg (per gummy)</td>
            <td>1-2 gummies</td>
            <td>3 gummies</td>
            <td>5 gummies</td>
            <td>Chamomile, lavender, valerian</td>
          </tr>
          <tr>
            <td><strong>Nature Made</strong></td>
            <td>3mg</td>
            <td>Half a gummy</td>
            <td>1 gummy</td>
