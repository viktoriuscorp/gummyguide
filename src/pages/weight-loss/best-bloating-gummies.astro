const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [
  { '@type': 'Question', name: 'What causes bloating?', acceptedAnswer: { '@type': 'Answer', text: 'Bloating is caused by excess gas production in the digestive tract, fluid retention, or impaired gut motility. Common triggers include fermentable carbohydrates (FODMAPs), food intolerances (lactose, gluten), inadequate digestive enzyme production, gut microbiome imbalances (dysbiosis), eating too quickly, carbonated beverages, and hormonal fluctuations. Chronic bloating affects an estimated 16 to 31% of the general population and is the most commonly reported GI symptom. Identifying the root cause is essential for choosing the right bloating supplement — digestive enzymes for food intolerance, probiotics for dysbiosis, or herbal carminatives for gas production.' } },
