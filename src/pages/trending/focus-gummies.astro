---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AffiliateDisclaimer from '../../components/AffiliateDisclaimer.astro';
import AuthorBox from '../../components/AuthorBox.astro';

const title = "8 Best Focus Gummies (2026) — Nootropics Tested | GummyGuide";
const description = "Expert-tested focus gummies with lion's mane, L-theanine, and alpha-GPC for sustained cognitive clarity. Compare 8 top nootropic gummies for concentration and mental performance in 2026.";

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: '2026-03-21',
  dateModified: '2026-03-28',
  author: { '@type': 'Person', name: 'James Rodriguez', jobTitle: 'CPT, CSCS' },
  publisher: { '@type': 'Organization', name: 'GummyGuide', url: 'https://gummyguide.com' },
  image: 'https://gummyguide.com/images/og/focus-gummies.webp',
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Best Focus Gummies 2026',
  numberOfItems: 8,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Onnit Alpha Brain Gummies', url: 'https://onnit.com/' },
    { '@type': 'ListItem', position: 2, name: 'Thesis Nootropic Gummies', url: 'https://takethesis.com/' },
    { '@type': 'ListItem', position: 3, name: 'FOCL Day Gummies', url: 'https://focl.com/' },
