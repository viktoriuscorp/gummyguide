---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const pageTitle = 'Affiliate Disclosure — How GummyGuide Makes Money | GummyGuide';
const pageDescription = 'Full FTC-compliant affiliate disclosure. Learn how GummyGuide earns revenue through affiliate commissions and how this affects our recommendations.';
---

<BaseLayout title={pageTitle} description={pageDescription}>

  <div class="pg-hero">
    <h1>Affiliate Disclosure</h1>
    <p class="pg-sub">How GummyGuide earns revenue — and why it never affects our recommendations.</p>
  </div>

  <Breadcrumbs items={[{ label: 'Affiliate Disclosure', href: '/affiliate-disclosure/' }]} />

  <div class="w">

    <p><strong>Last updated: March 2026</strong></p>

    <p>GummyGuide is a participant in various affiliate advertising programs designed to provide a means for sites to earn advertising fees by advertising and linking to retail websites.</p>

    <h2>How It Works</h2>

    <div class="info-cards">
      <div class="info-card">
        <h3>You Click a Product Link</h3>
        <p>When you click on a product link on GummyGuide and make a purchase, we may receive a small commission from the retailer.</p>
      </div>
      <div class="info-card">
        <h3>No Extra Cost to You</h3>
        <p>This happens at no additional cost to you. The price you pay is the same whether you use our link or go directly to the store.</p>
      </div>
    </div>

    <h2>Affiliate Programs We Participate In</h2>

    <div class="info-cards">
      <div class="info-card">
        <h3>Amazon Associates</h3>
        <p>As an Amazon Associate, we earn from qualifying purchases made through our product links to Amazon.com.</p>
      </div>
      <div class="info-card">
        <h3>Direct Brand Programs</h3>
        <p>We partner with supplement brands through affiliate networks like ShareASale, Impact, and Awin for direct-to-brand purchases.</p>
      </div>
    </div>

    <h2>Our Commitment to Honesty</h2>

    <div class="callout">
      Affiliate commissions <strong>never influence our product rankings, reviews, or recommendations</strong>. Our editorial team evaluates products based on ingredient quality, third-party testing, taste, value, and clinical evidence — not on which product pays the highest commission.
    </div>

    <p>We frequently recommend products that do not have affiliate programs, and we have published negative reviews of products from our affiliate partners. Our readers' trust is more valuable than any commission.</p>

    <h2>How to Identify Affiliate Links</h2>

    <div class="tip-box">
      <div class="tip-box-ico">i</div>
      <p>Affiliate links on GummyGuide are marked with <code>rel="nofollow sponsored"</code> attributes. Buttons labeled <strong>"Check Price at [Brand]"</strong> or <strong>"[Brand Name] on Amazon"</strong> are affiliate links. Clicking them may generate a commission for us at no cost to you.</p>
    </div>

    <h2>FTC Compliance</h2>

    <p>This disclosure is provided in accordance with the Federal Trade Commission's <em>Guides Concerning the Use of Endorsements and Testimonials in Advertising</em> (16 CFR Part 255).</p>

    <h2>Questions?</h2>

    <p>If you have any questions about our affiliate relationships, please contact us at <strong>hello@gummy-guide.com</strong>.</p>

    <div class="cta">
      <h2>See Our Independent Reviews</h2>
      <p>Every product purchased with our own money. Every review based on real testing.</p>
      <a href="/editorial-process/" class="btn btn-wh">How We Test →</a>
    </div>

  </div>

</BaseLayout>
