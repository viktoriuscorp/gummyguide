const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [
  { '@type': 'Question', name: 'What does hyaluronic acid do for your skin?', acceptedAnswer: { '@type': 'Answer', text: 'Hyaluronic acid (HA) is a naturally occurring glycosaminoglycan found throughout the body, with the highest concentrations in skin, eyes, and joint fluid. In the skin, HA acts as a humectant — it binds up to 1,000 times its weight in water, creating a hydrated, plump appearance. HA is a key component of the extracellular matrix that supports collagen and elastin fibers. Skin HA content decreases significantly with age — by age 50, the body retains only about half the HA it had at age 20. Oral HA supplementation has been shown in multiple clinical trials to significantly improve skin hydration, reduce wrinkle depth, and increase skin elasticity within 4-8 weeks.' } },
  { '@type': 'Question', name: 'Do oral hyaluronic acid supplements actually work?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. A 2017 meta-analysis in the Journal of Clinical and Aesthetic Dermatology analyzed 13 clinical trials and found that oral hyaluronic acid supplementation at 80-200mg daily significantly improved skin hydration and reduced wrinkle depth compared to placebo. The mechanism involves absorption of HA fragments in the gut, which are transported to the skin via the bloodstream and stimulate fibroblasts to produce more endogenous HA and collagen. A key 2014 study published in Nutrition Journal demonstrated that oral HA at 120mg daily for 12 weeks improved skin moistness by 44.3% compared to baseline, with visible wrinkle reduction.' } },
