<div class="pcard-specs"><div class="pcard-spec"><strong>Hyaluronic Acid</strong><span>240mg per serving</span></div><div class="pcard-spec"><strong>Vitamin C</strong><span>120mg per serving</span></div><div class="pcard-spec"><strong>Vitamin E</strong><span>30mg per serving</span></div><div class="pcard-spec"><strong>Added</strong><span>Grapeseed extract antioxidant</span></div></div>
