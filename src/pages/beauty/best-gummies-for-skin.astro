  description,
  datePublished: '2026-03-28',
  dateModified: '2026-03-28',
  author: { '@type': 'Person', name: 'Sarah Mitchell', jobTitle: 'RD, CNS' },
  publisher: { '@type': 'Organization', name: 'GummyGuide', url: 'https://gummy-guide.com' },
  image: 'https://gummy-guide.com/images/og/best-gummies-for-skin.webp',
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Best Gummies for Skin 2026',
  numberOfItems: 7,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Vital Proteins Collagen Gummies', url: 'https://gummy-guide.com/beauty/best-gummies-for-skin/#vital-proteins' },
