---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | GummyGuide" description="The page you're looking for doesn't exist. Browse our expert-tested gummy supplement guides instead." noindex={true}>

  <section style="text-align:center;padding:80px 20px 40px;">
    <p style="font-size:120px;font-weight:800;color:#3D4F2F;line-height:1;margin:0 0 8px;">404</p>
    <h1 style="font-size:28px;color:#1A1A1A;margin:0 0 12px;">Page Not Found</h1>
    <p style="font-size:17px;color:#6B6B6B;max-width:480px;margin:0 auto 40px;line-height:1.6;">This page doesn't exist — but our supplement guides do.</p>
  </section>

  <div class="w">

    <div class="info-cards" style="margin-bottom:48px;">
      <a href="/best-creatine-gummies/" class="info-card" style="text-decoration:none;color:inherit;transition:transform .2s,box-shadow .2s;">
        <h4>Best Creatine Gummies</h4>
        <p>Top-rated creatine gummies for strength, performance, and cognitive support — tested and ranked by our editorial team.</p>
      </a>
      <a href="/best-sleep-gummies/" class="info-card" style="text-decoration:none;color:inherit;transition:transform .2s,box-shadow .2s;">
        <h4>Best Sleep Gummies</h4>
        <p>Melatonin, magnesium, and calming blends reviewed for ingredient quality, dosing, and real-world effectiveness.</p>
      </a>
      <a href="/best-mushroom-gummies/" class="info-card" style="text-decoration:none;color:inherit;transition:transform .2s,box-shadow .2s;">
        <h4>Best Mushroom Gummies</h4>
        <p>Lion's mane, reishi, and functional mushroom blends evaluated for potency, beta-glucan content, and third-party testing.</p>
      </a>
      <a href="/best-ashwagandha-gummies/" class="info-card" style="text-decoration:none;color:inherit;transition:transform .2s,box-shadow .2s;">
        <h4>Best Ashwagandha Gummies</h4>
        <p>KSM-66 and Sensoril ashwagandha gummies compared for stress relief, cortisol reduction, and adaptogenic benefits.</p>
      </a>
    </div>

    <div style="text-align:center;margin-bottom:56px;">
      <a href="/" class="btn btn-grn" style="display:inline-block;">Back to Homepage</a>
    </div>

  </div>

</BaseLayout>

<style>
  .info-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }
</style>
