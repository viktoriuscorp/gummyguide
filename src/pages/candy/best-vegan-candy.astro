const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What makes candy non-vegan?',
      acceptedAnswer: { '@type': 'Answer', text: 'The most common non-vegan ingredients in candy are: gelatin (protein from animal bones and skin, used in gummy candy), beeswax (used as a coating/glazing agent), shellac/confectioner\'s glaze (secreted by lac insects, used for shiny coatings), carmine/cochineal (red pigment from crushed cochineal insects, used as a colorant), dairy (milk chocolate, milk powder, whey, casein), and eggs (egg albumen in some marshmallows and nougat). White refined sugar is a gray area — some cane sugar refineries use bone char (animal bone charcoal) as a decolorizing filter, though no bone material remains in the final product. Organic sugar, beet sugar, and coconut sugar never use bone char.' },
    },
    {
      '@type': 'Question',
      name: 'Is dark chocolate vegan?',
      acceptedAnswer: { '@type': 'Answer', text: 'Pure dark chocolate (cacao, cocoa butter, sugar) is vegan by ingredient. However, many commercial dark chocolate products contain milk fat, milk powder, or butterfat as secondary ingredients — even dark chocolate bars. Always check the ingredient list rather than relying on the "dark chocolate" label. Brands that are reliably vegan-friendly include Hu Kitchen (paleo, no refined sugar, dairy-free), Endangered Species (Fair Trade, dairy-free varieties clearly labeled), Alter Eco (organic, Fair Trade, specific vegan varieties), and Enjoy Life (free of top 14 allergens). The safest approach is to look for dark chocolate explicitly labeled "dairy-free" or "vegan."' },
    },
    {
      '@type': 'Question',
      name: 'Are Skittles vegan?',
      acceptedAnswer: { '@type': 'Answer', text: 'Skittles removed gelatin from their recipe in 2009, and the current formula does not contain any direct animal-derived ingredients. The shell coating uses a modified starch instead of confectioner\'s glaze (shellac), and the colors are synthetic (not carmine). However, like Swedish Fish and Sour Patch Kids, Skittles contain sugar that may be refined with bone char and artificial colors that were historically tested on animals. Dietary vegans generally consider Skittles acceptable; strict ethical vegans may avoid them. Skittles do not carry vegan certification from any third-party organization.' },
    },
    {
      '@type': 'Question',
      name: 'Are Oreos vegan?',
      acceptedAnswer: { '@type': 'Answer', text: 'Oreos do not contain any direct animal ingredients in their recipe — no dairy, eggs, or animal fats. The original Oreo recipe used lard, but Nabisco switched to vegetable oils in the 1990s. However, Oreos are produced on shared equipment with dairy-containing products, meaning cross-contamination is possible. Oreo\'s own website states: "Oreos are not suitable for vegans as they have milk as cross-contact." For vegans who avoid cross-contamination risk, dedicated vegan sandwich cookies from brands like Back to Nature or Newman-O\'s (organic) are safer alternatives. For vegans who focus only on intentional ingredients, Oreos are technically acceptable.' },
    },
    {
      '@type': 'Question',
      name: 'What is the best vegan chocolate?',
      acceptedAnswer: { '@type': 'Answer', text: 'Our top picks for vegan chocolate are: Hu Kitchen Chocolate Gems (best overall — simple ingredients, no refined sugar, dairy-free, soy-free), Unreal Dark Chocolate Peanut Butter Cups (best Reese\'s alternative — Fair Trade chocolate, 5 ingredients), Endangered Species Dark Chocolate (best value — Fair Trade, organic cocoa, 10% profits to wildlife), and Alter Eco Dark Chocolate Truffles (best premium — organic, Fair Trade, compostable packaging). All four brands use cocoa butter rather than milk fat, organic or Fair Trade cacao, and transparent ingredient sourcing. For milk chocolate texture in a vegan format, look for bars made with oat milk or coconut milk as the dairy substitute.' },
    },
    {
      '@type': 'Question',
      name: 'Are gummy vitamins vegan?',
      acceptedAnswer: { '@type': 'Answer', text: 'Most mainstream gummy vitamins contain gelatin as the gelling agent — brands like Vitafusion, Nature Made, and Centrum gummies all use animal-derived gelatin. However, a growing number of brands offer pectin-based vegan gummy vitamins: SmartyPants (some varieties), MaryRuth Organics (all vegan), Hilo Nutrition, and OLLY (select products labeled "vegan"). The key is to look for "pectin" in the ingredient list and "vegan" on the label. For a comprehensive guide to vegan gummy vitamins across every supplement category, see our vegan gummies supplement hub.' },
    },
    {
      '@type': 'Question',
      name: 'How can I tell if candy is vegan?',
      acceptedAnswer: { '@type': 'Answer', text: 'Three-step check: (1) Look for a "Certified Vegan" logo from recognized bodies like the Vegan Society or Vegan Action — this is the most reliable indicator. (2) If no certification, read the ingredient list and check for gelatin, beeswax, shellac/confectioner\'s glaze, carmine/cochineal, dairy ingredients (milk, whey, casein, lactose), and eggs. (3) For gray-area ingredients (sugar, natural flavors, artificial colors), decide your personal threshold — dietary vegans accept products free of direct animal ingredients, while strict ethical vegans may avoid bone-char-processed sugar and animal-tested additives. When in doubt, brands with USDA Organic certification use sugar that was not refined with bone char.' },
    },
    {
      '@type': 'Question',
      name: 'What are the best vegan candy brands?',
      acceptedAnswer: { '@type': 'Answer', text: 'The top vegan candy brands in 2026 are: Surf Sweets (best vegan gummies — USDA Organic, pectin-based, allergen-free), SmartSweets (best low-sugar vegan gummies — pectin + fiber, 3g sugar per bag), Hu Kitchen (best vegan chocolate — no refined sugar, dairy-free, soy-free), Unreal Candy (best vegan chocolate candy — Fair Trade, simple ingredients), YumEarth (best vegan candy for kids — organic, allergen-free, individually wrapped), Black Forest (best value vegan gummies — USDA Organic, lowest price per ounce), and Project 7 (best mission-driven — every purchase supports charitable causes). All of these brands use plant-based gelling agents, organic or non-bone-char sugar, and natural colors.' },
    },
  ],
};
