const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What makes gummy candy vegan?',
      acceptedAnswer: { '@type': 'Answer', text: 'Vegan gummy candy replaces animal-derived gelatin with plant-based gelling agents like pectin (from citrus peel or apple pomace), agar-agar (from seaweed), or starch-based formulations. It must also exclude beeswax, carmine (a red dye from insects), shellac (confectioner\'s glaze), and any other animal-derived ingredient. Most vegan gummy candy uses natural fruit juices and plant-based colorants instead.' },
    },
    {
      '@type': 'Question',
      name: 'Does vegan gummy candy taste different from regular gummy candy?',
      acceptedAnswer: { '@type': 'Answer', text: 'The flavor difference is minimal in modern formulations. Pectin-based gummies tend to be slightly softer and less chewy than gelatin gummies, with a texture closer to a fruit snack. Many consumers actually prefer the pectin texture because it feels less "rubbery" and has a more immediate fruit flavor release. Premium brands like SmartSweets and Surf Sweets have formulations that are virtually indistinguishable from traditional gummy candy in blind taste tests.' },
    },
    {
      '@type': 'Question',
      name: 'Are SmartSweets gummy bears actually healthy?',
      acceptedAnswer: { '@type': 'Answer', text: 'SmartSweets contain only 3g of sugar per bag compared to 34g in traditional Haribo gummy bears, making them a dramatically lower-sugar option. They are sweetened with allulose (a rare sugar with minimal caloric impact) and stevia. However, they still contain calories, and the fiber content comes from added soluble corn fiber, not from whole food sources. They are a healthier alternative to conventional candy, but they are still candy — not a health food.' },
    },
    {
      '@type': 'Question',
      name: 'What is the healthiest vegan gummy candy?',
      acceptedAnswer: { '@type': 'Answer', text: 'SmartSweets leads in sugar reduction (3g per bag). YumEarth uses only organic ingredients with no synthetic dyes. Surf Sweets is USDA Organic with real fruit juice. For the absolute healthiest option, SmartSweets offers the best macro profile — low sugar, moderate fiber, plant-based ingredients. For clean ingredients, YumEarth and Surf Sweets prioritize organic certification and real fruit juice over sugar substitutes.' },
    },
    {
      '@type': 'Question',
      name: 'Is Haribo gummy candy vegan?',
      acceptedAnswer: { '@type': 'Answer', text: 'No. Haribo gummy bears and most Haribo products contain gelatin derived from animal collagen (typically pork). They also contain beeswax as a glazing agent. Haribo does not currently offer a vegan-certified gummy line in the United States. For a similar gummy bear experience without gelatin, SmartSweets, YumEarth, and Black Forest Organic are the closest alternatives.' },
    },
    {
      '@type': 'Question',
      name: 'Are vegan gummy candies gluten-free?',
      acceptedAnswer: { '@type': 'Answer', text: 'Most vegan gummy candy is naturally gluten-free because the primary ingredients — pectin, sugar, fruit juice, and natural flavors — do not contain gluten. Brands like SmartSweets, YumEarth, and Surf Sweets are certified gluten-free. However, always check the label for cross-contamination warnings, especially if you have celiac disease, as some manufacturing facilities also process wheat-containing products.' },
    },
    {
      '@type': 'Question',
      name: 'Where can I buy vegan gummy candy?',
      acceptedAnswer: { '@type': 'Answer', text: 'Vegan gummy candy is widely available at major retailers including Amazon, Whole Foods, Target, Walmart, Trader Joe\'s, and Sprouts. Amazon offers the widest selection and frequently has multi-pack bundles at lower per-unit prices. Whole Foods and Sprouts carry the largest in-store selections of organic and specialty vegan candy brands.' },
    },
    {
      '@type': 'Question',
      name: 'How can I tell if gummy candy contains gelatin?',
      acceptedAnswer: { '@type': 'Answer', text: 'Check the ingredient list for "gelatin" — it is a required disclosure. Also look for beeswax (often listed as "glazing agent" or "coating"), carmine or cochineal extract (red color from insects, also listed as E120), and shellac (also called "confectioner\'s glaze"). Products using pectin, agar, or starch as the gelling agent will list those instead. Certified Vegan or Vegan Society logos provide the fastest verification.' },
    },
  ],
};
