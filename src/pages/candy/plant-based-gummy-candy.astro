const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is plant-based gummy candy?',
      acceptedAnswer: { '@type': 'Answer', text: 'Plant-based gummy candy uses plant-derived gelling agents — pectin (from citrus peel or apple pomace), agar-agar (from seaweed), or tapioca starch — instead of animal-derived gelatin. It also excludes beeswax, carmine (insect-derived red dye), shellac, and any other animal-sourced ingredient. The term "plant-based" is interchangeable with "vegan" in the candy context, though some products may use plant-based gelling while still containing beeswax coating.' },
    },
    {
      '@type': 'Question',
      name: 'What types of plant-based candy are available?',
      acceptedAnswer: { '@type': 'Answer', text: 'Plant-based candy now covers virtually every candy type: gummy bears, gummy worms (sour and fruity), gummy rings, fruit snacks, fruit strips/leather, sour belts, licorice, chocolate bars, chocolate-covered nuts, peanut butter cups, hard candy, lollipops, caramels, and more. The gummy and chocolate categories have the widest selection of plant-based options.' },
    },
    {
      '@type': 'Question',
      name: 'Is plant-based candy healthier than regular candy?',
      acceptedAnswer: { '@type': 'Answer', text: 'It depends on the specific product. Plant-based candy can range from low-sugar options like SmartSweets (3g sugar per bag) to organic brands with comparable sugar to conventional candy. The consistent health advantage of plant-based candy is the absence of synthetic dyes and artificial flavors — most plant-based brands use natural colorants from fruit, vegetable, and spice extracts. For the healthiest options, look for brands that are both plant-based AND low-sugar.' },
    },
    {
      '@type': 'Question',
      name: 'What popular candy brands are NOT plant-based?',
      acceptedAnswer: { '@type': 'Answer', text: 'Haribo (gelatin + beeswax), Trolli (gelatin + artificial colors), Swedish Fish (beeswax in some formulations), Sour Patch Kids (gelatin-free but contains non-vegan sugar processing in some definitions), Starburst (gelatin), Skittles (no gelatin but contains confectioner\'s glaze/shellac in some markets). Always check the specific product and market — formulations vary by country.' },
    },
    {
      '@type': 'Question',
      name: 'Are Skittles plant-based?',
      acceptedAnswer: { '@type': 'Answer', text: 'Skittles removed gelatin from their recipe in 2009 and are now gelatin-free. However, they contain artificial colors (Red 40, Yellow 5, Yellow 6, Blue 1) and their sugar may be processed with bone char (an animal-derived filtering agent) depending on the sugar supplier. Strict vegans often avoid Skittles due to the bone char sugar processing question. Most plant-based candy guides do not classify Skittles as fully plant-based.' },
    },
    {
      '@type': 'Question',
      name: 'What makes gummy candy not vegan?',
      acceptedAnswer: { '@type': 'Answer', text: 'The most common non-vegan ingredients in gummy candy are: gelatin (animal collagen, usually from pork or beef), beeswax (used as a glazing/coating agent), carmine/cochineal/E120 (red pigment from crushed cochineal insects), shellac/confectioner\'s glaze (resin secreted by lac insects), and lanolin-derived ingredients. Some strict vegans also avoid sugar processed with bone char, though this is debated within the vegan community.' },
    },
    {
      '@type': 'Question',
      name: 'Where is the best place to buy plant-based candy?',
      acceptedAnswer: { '@type': 'Answer', text: 'Amazon offers the widest selection and best multi-pack pricing with Subscribe & Save discounts. Whole Foods has the largest in-store selection of plant-based candy brands. Target and Walmart carry mainstream plant-based options like SmartSweets and YumEarth. Trader Joe\'s has popular house-brand options like Scandinavian Swimmers. Sprouts and Natural Grocers carry niche organic brands.' },
    },
    {
      '@type': 'Question',
      name: 'Is plant-based candy more expensive than regular candy?',
      acceptedAnswer: { '@type': 'Answer', text: 'Premium plant-based candy brands like SmartSweets ($3.49/bag) cost 2-3x more than conventional candy like Haribo ($1.29/bag). However, organic value brands like Black Forest ($0.99/bag) and YumEarth ($1.29/bag) are price-competitive with mainstream candy. The price gap has narrowed significantly as plant-based candy has gained scale. Buying in multi-packs on Amazon with Subscribe & Save is the most cost-effective approach for premium brands.' },
    },
  ],
};
