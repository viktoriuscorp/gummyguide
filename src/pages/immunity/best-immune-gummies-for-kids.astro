const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [
  { '@type': 'Question', name: 'What are the most important immune nutrients for kids?', acceptedAnswer: { '@type': 'Answer', text: 'The three most evidence-based immune nutrients for children are vitamin C, zinc, and vitamin D3. Vitamin C concentrates in immune cells at 10-100x plasma levels and supports neutrophil and lymphocyte function. Zinc is required for immune cell development, communication, and function — zinc deficiency impairs both innate and adaptive immunity. Vitamin D3 regulates over 200 immune-related genes and deficiency is associated with increased susceptibility to respiratory infections. Elderberry extract provides anthocyanin antioxidants with demonstrated antiviral properties in laboratory studies, though pediatric clinical data is limited.' } },
