---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const pageTitle = 'How We Test Gummy Supplements — Our Editorial Process | GummyGuide';
const pageDescription = 'Our transparent methodology for testing and reviewing gummy supplements. Learn how we evaluate ingredients, dosages, third-party testing, taste, and value.';
---

<BaseLayout title={pageTitle} description={pageDescription}>

  <div class="pg-hero">
    <h1>How We Test & Review Gummy Supplements</h1>
    <p class="pg-sub">Transparency is the foundation of everything we do. This page explains exactly how we evaluate, test, and rank every product we recommend.</p>
    <div class="pg-meta">
      <span>Independent Reviews</span>
      <span>No Free Samples</span>
      <span>Updated Quarterly</span>
    </div>
  </div>

  <Breadcrumbs items={[{ label: 'Editorial Process', href: '/editorial-process/' }]} />

  <div class="w">

    <div class="key-stat">
      <div class="key-stat-num">200+</div>
      <p class="key-stat-txt">products purchased with our own money and tested by our team of <strong>registered dietitians</strong>. No free samples. No sponsored placements. No exceptions.</p>
    </div>

    <h2>Our 6-Step Testing Process</h2>

    <div class="info-cards">
      <div class="info-card">
        <div class="info-card-ico">1</div>
        <h4>Product Selection</h4>
        <p>For each category, we identify the 15-25 most popular products based on Amazon sales data, brand reputation, social media mentions, and reader requests. We purchase every product with our own funds.</p>
      </div>
      <div class="info-card">
        <div class="info-card-ico">2</div>
        <h4>Ingredient Analysis</h4>
        <p>We compare every supplement facts panel against clinically studied dosages from peer-reviewed research on PubMed. We verify bioavailability of ingredient forms and flag unnecessary fillers.</p>
      </div>
      <div class="info-card">
        <div class="info-card-ico">3</div>
        <h4>Third-Party Testing</h4>
        <p>We verify independent certifications from NSF International, USP, ConsumerLab, and Informed Sport. Products with third-party testing receive higher scores in our rankings.</p>
      </div>
      <div class="info-card">
        <div class="info-card-ico">4</div>
        <h4>Hands-On Testing</h4>
        <p>Every gummy is tested for taste, texture, and real-world experience over a minimum 2-week period. We evaluate serving size, packaging, and daily usability.</p>
      </div>
      <div class="info-card">
        <div class="info-card-ico">5</div>
        <h4>Scoring & Ranking</h4>
        <p>Products are scored across five weighted criteria: Ingredient Quality (30%), Third-Party Testing (25%), Taste & Experience (20%), Value (15%), and Brand Reputation (10%).</p>
      </div>
      <div class="info-card">
        <div class="info-card-ico">6</div>
        <h4>Quarterly Updates</h4>
        <p>We revisit every guide quarterly. When new products launch, research is published, or formulations change, we update our recommendations. Every article shows publish and update dates.</p>
      </div>
    </div>

    <h2>What We Evaluate</h2>

    <div class="callout">
      Does the product contain the clinically effective dose? Is the ingredient form bioavailable? Are claims supported by human clinical trials — not just animal or in-vitro studies?
      <cite>— The three questions we ask about every product</cite>
    </div>

    <div class="info-cards">
      <div class="info-card">
        <h4>Ingredient Quality (30%)</h4>
        <p>Clinical dosing, standardized extracts, evidence-based formulations. We cross-reference every dose against published research from PubMed and NIH databases.</p>
      </div>
      <div class="info-card">
        <h4>Third-Party Testing (25%)</h4>
        <p>NSF International verifies contaminants and label accuracy. USP checks purity and potency. ConsumerLab provides independent testing. Informed Sport tests for banned substances.</p>
      </div>
      <div class="info-card">
        <h4>Taste & Experience (20%)</h4>
        <p>Flavor, texture, aftertaste, serving size, and daily compliance. A supplement only works if people actually take it consistently.</p>
      </div>
      <div class="info-card">
        <h4>Value & Reputation (25%)</h4>
        <p>Price per serving relative to ingredient quality, manufacturing standards (GMP, cGMP), transparency, and customer service track record.</p>
      </div>
    </div>

    <h2>Our Independence</h2>

    <div class="tip-box">
      <div class="tip-box-ico">i</div>
      <p><strong>We never accept free products, sponsored placements, or payment in exchange for reviews.</strong> Our affiliate relationships do not influence rankings. If a product is bad, we say so — regardless of whether we earn a commission from it.</p>
    </div>

    <p>Every reviewer on our team discloses their credentials, experience, and methodology. We believe the supplement industry needs more honest, independent voices — and that starts with full transparency about how we work.</p>

    <div class="warn-box">
      <div class="warn-box-ico">!</div>
      <p><strong>Important:</strong> Our reviews are for informational purposes only and do not constitute medical advice. Always consult your healthcare provider before starting any new supplement regimen.</p>
    </div>

    <p>Questions about our process? Email us at <strong>hello@gummyguide.com</strong>.</p>

    <div class="cta">
      <h2>See Our Reviews in Action</h2>
      <p>Explore our expert-tested buying guides across 9 supplement categories.</p>
      <a href="/#picks" class="btn btn-wh">Explore All Guides →</a>
    </div>

  </div>

</BaseLayout>
