const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: '2026-03-28',
  dateModified: '2026-03-28',
  author: { '@type': 'Person', name: 'Sarah Mitchell', jobTitle: 'RD, CNS' },
  publisher: { '@type': 'Organization', name: 'GummyGuide', url: 'https://gummy-guide.com' },
  image: 'https://gummy-guide.com/images/og/omega-3-gummies.webp',
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Best Omega-3 Gummies 2026',
  numberOfItems: 8,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'SmartyPants Adult Formula Omega-3 Gummies', url: 'https://www.amazon.com/dp/B0SMARTYOM3' },
