  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: '2026-03-28',
  dateModified: '2026-03-28',
  author: { '@type': 'Person', name: 'Sarah Mitchell', jobTitle: 'RD, CNS' },
  publisher: { '@type': 'Organization', name: 'GummyGuide', url: 'https://gummy-guide.com' },
  image: 'https://gummy-guide.com/images/og/vitamin-b-complex-gummies.webp',
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Best Vitamin B Complex Gummies 2026',
  numberOfItems: 7,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Nature Made Super B Complex Gummies', url: 'https://gummy-guide.com/vitamins/vitamin-b-complex-gummies/#nature-made' },
    { '@type': 'ListItem', position: 2, name: 'Garden of Life B Complex Gummies', url: 'https://gummy-guide.com/vitamins/vitamin-b-complex-gummies/#garden' },
    { '@type': 'ListItem', position: 3, name: 'MegaFood B Complex Gummies', url: 'https://gummy-guide.com/vitamins/vitamin-b-complex-gummies/#megafood' },
    { '@type': 'ListItem', position: 4, name: 'Vitafusion B Complex Gummies', url: 'https://gummy-guide.com/vitamins/vitamin-b-complex-gummies/#vitafusion' },
    { '@type': 'ListItem', position: 5, name: 'Nordic Naturals B Complex Gummies', url: 'https://gummy-guide.com/vitamins/vitamin-b-complex-gummies/#nordic' },
