  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Fungies Reishi Gummies', url: 'https://gummy-guide.com/mushroom/reishi-gummies/#fungies' },
    { '@type': 'ListItem', position: 2, name: 'Real Mushrooms Reishi 415', url: 'https://gummy-guide.com/mushroom/reishi-gummies/#real-mushrooms' },
