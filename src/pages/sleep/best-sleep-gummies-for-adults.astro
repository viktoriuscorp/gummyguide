const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: [
  { '@type': 'Question', name: 'What is the best dose of melatonin for adults?', acceptedAnswer: { '@type': 'Answer', text: 'Research suggests that lower melatonin doses (0.5 to 3mg) are often more effective than higher doses for most adults. A 2013 meta-analysis in PLOS ONE found that melatonin at doses of 0.5 to 5mg reduced sleep onset latency by an average of 7 minutes and increased total sleep time by 8 minutes. The American Academy of Sleep Medicine suggests starting with the lowest effective dose. Higher doses (5 to 10mg) may cause grogginess, vivid dreams, or morning drowsiness without proportionally better sleep quality. Start with 1 to 3mg and increase only if needed.' } },
  { '@type': 'Question', name: 'Are sleep gummies safe for long-term use?', acceptedAnswer: { '@type': 'Answer', text: 'Melatonin gummies are generally considered safe for short to medium-term use (up to 3 months) based on clinical trial data. Long-term safety data beyond 3 months is limited. The American Academy of Sleep Medicine does not recommend long-term melatonin use without medical supervision. Non-melatonin ingredients like L-theanine, magnesium, and chamomile have better long-term safety profiles and can be used continuously. If you rely on sleep gummies nightly for more than 3 months, consult a sleep specialist to address underlying sleep issues.' } },
