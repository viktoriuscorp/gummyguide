  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: '2026-03-28',
  dateModified: '2026-03-28',
  author: { '@type': 'Person', name: 'Sarah Mitchell', jobTitle: 'RD, CNS' },
  publisher: { '@type': 'Organization', name: 'GummyGuide', url: 'https://gummy-guide.com' },
  image: 'https://gummy-guide.com/images/og/gummies-anxiety.webp',
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Best Gummies for Anxiety 2026',
  numberOfItems: 8,
  itemListElement: [
