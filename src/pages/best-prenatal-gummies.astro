---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AffiliateDisclaimer from '../components/AffiliateDisclaimer.astro';
import AuthorBox from '../components/AuthorBox.astro';

const title = '8 Best Prenatal Gummies (2026) — OB-GYN Approved | GummyGuide';
const description = 'editorially reviewed prenatal gummies with folate, DHA, and iron. Compare the best prenatal vitamins in gummy form for pregnancy and planning in 2026.';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Best Prenatal Gummies',
  description,
  author: {
    '@type': 'Person',
    name: 'Sarah Mitchell',
    jobTitle: 'RD, CNS',
  },
  publisher: {
    '@type': 'Organization',
    name: 'GummyGuide',
    url: 'https://gummy-guide.com',
  },
  datePublished: '2026-03-10',
  dateModified: '2026-03-28',
  mainEntityOfPage: 'https://gummy-guide.com/best-prenatal-gummies/',
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Best Prenatal Gummies 2026',
  numberOfItems: 8,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'One A Day Prenatal Gummies', url: 'https://www.amazon.com/s?k=One+A+Day+Prenatal+Gummies&tag=gummyguide-20' },
