          <div class="pcard-stars">
            <span class="stars">&#9733;&#9733;&#9733;&#9733;&#9734;</span>
            <span class="rating-val">4.6</span>
            <span class="review-ct">(25,678 reviews)</span>
          </div>
          <div class="pcard-specs">
            <div class="pcard-spec"><strong>Fiber Type</strong><span>Chicory Root Fiber + B Vitamins</span></div>
            <div class="pcard-spec"><strong>Dose</strong><span>5g fiber per serving</span></div>
            <div class="pcard-spec"><strong>Servings</strong><span>60 per container</span></div>
