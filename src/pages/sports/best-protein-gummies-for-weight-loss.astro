const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Can protein gummies help with weight loss?',
      acceptedAnswer: { '@type': 'Answer', text: 'Protein gummies can support weight loss by providing a high-protein, low-sugar snack that promotes satiety between meals. Research consistently shows that protein is the most satiating macronutrient — a 2015 meta-analysis in the American Journal of Clinical Nutrition found that higher protein intake (25-30g per meal) reduces overall caloric intake by promoting fullness and reducing hunger hormones (ghrelin). Protein gummies typically provide 10-15g protein per serving at 60-120 calories, making them a significantly better snacking choice than candy, chips, or traditional gummy bears. However, they are supplements, not meal replacements — they work best as between-meal satiety tools within a calorie-controlled diet.' },
